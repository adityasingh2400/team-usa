# Copy to .env.local and fill in values. Never commit .env.local.

# Required: your GCP project ID
GCP_PROJECT_ID=your-project-id

# Optional: Vertex AI region (default: us-central1)
GCP_LOCATION=us-central1

# Optional: Gemini model (default: gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# Auth: either set GOOGLE_APPLICATION_CREDENTIALS to a service account key path,
# or run `gcloud auth application-default login` for local dev.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
